# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS Resources (will be populated after deployment)
COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
DYNAMODB_TABLE_NAME=ClarityBridge-Main
S3_BUCKET_NAME=claritybridge-uploads-123456789012
S3_FRONTEND_BUCKET=claritybridge-frontend-123456789012
CLOUDFRONT_DISTRIBUTION_ID=EXXXXXXXXXXXXXXXXX

# API Configuration
VITE_API_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod
FRONTEND_URL=https://dxxxxxxxxxxxxxxxxx.cloudfront.net

# External Services
OPENAI_API_KEY=your_openai_api_key_here
HIGHNOTE_API_KEY=your_highnote_api_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Email Configuration
SES_FROM_EMAIL=noreply@claritybridge.com
SES_REPLY_TO_EMAIL=support@claritybridge.com

# Application Configuration
NODE_ENV=development
LOG_LEVEL=info
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000